{
  "shadow": {
    "sm": { "$value": "0 1px 2px 0 rgb(2 6 23 / 0.06)", "$type": "shadow" },
    "md": {
      "$value": "0 2px 4px -1px rgb(2 6 23 / 0.08), 0 4px 8px -2px rgb(2 6 23 / 0.06)",
      "$type": "shadow"
    },
    "lg": {
      "$value": "0 4px 8px -2px rgb(2 6 23 / 0.1), 0 12px 24px -4px rgb(2 6 23 / 0.08)",
      "$type": "shadow"
    },
    "xl": {
      "$value": "0 8px 16px -4px rgb(2 6 23 / 0.12), 0 24px 48px -8px rgb(2 6 23 / 0.14)",
      "$type": "shadow"
    }
  },
  "motion": {
    "duration": {
      "fast": { "$value": "120ms", "$type": "duration" },
      "base": { "$value": "200ms", "$type": "duration" },
      "slow": { "$value": "320ms", "$type": "duration" }
    },
    "easing": {
      "standard": { "$value": "cubic-bezier(0.2, 0, 0, 1)", "$type": "cubicBezier" },
      "enter": { "$value": "cubic-bezier(0, 0, 0.2, 1)", "$type": "cubicBezier" },
      "exit": { "$value": "cubic-bezier(0.4, 0, 1, 1)", "$type": "cubicBezier" }
    }
  }
}
